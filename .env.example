HOST=http://localhost:8080
# HOST=https://deliveroojs.azurewebsites.net/
# HOST=https://deliveroojs.bears.disi.unitn.it/

# Single-agent token (used by src/ and src_baseline/ when run directly)
TOKEN=your_token_here

# ── Baseline agents (used by run_baselines.js) ───────────────────────────────
# Add one TOKEN_N per baseline instance. The launcher spawns one process per token.
TOKEN_1=first_baseline_token
# TOKEN_2=second_baseline_token
# TOKEN_3=third_baseline_token
