# This is an example .env file for the Autonomous Software Agents project.
# Copy this file to .env and fill in and comment the appropriate values.

# HOST is the URL of the server to connect to. You can use the local server for development or the public servers for testing and challenges.
HOST=http://localhost:8080
HOST=https://deliveroojs.azurewebsites.net/
HOST=https://deliveroojs.bears.disi.unitn.it/

# Single-agent token (used by src_bdi/ and src_baseline/ when run directly)
TOKEN=your_token_here

# Baseline agents (used by run_baselines.js)
# Add one TOKEN_N per baseline instance. The launcher spawns one process per token.
TOKEN_1=first_baseline_token
TOKEN_2=second_baseline_token
TOKEN_3=third_baseline_token


# ================= LLM =======================

# Master:
TOKEN_LLM=your_master_token_here
# Slave:
TOKEN_SLAVE=your_slave_token_here

# LLM configuration
LITELLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LITELLM_API_KEY=<api_key>
LOCAL_MODEL=llama-3.3-70b-lmstudio # or any other model you would like to use